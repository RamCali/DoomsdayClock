# Neon.tech PostgreSQL connection string
# Get this from your Neon dashboard: https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Auth - JWT secret for signing tokens (generate a random 64-char string)
JWT_SECRET=your-random-secret-here

# Resend - for verification and password reset emails
# Get API key from: https://resend.com
RESEND_API_KEY=re_your_api_key_here

# SendX - for newsletter / Doomsday Clock update subscribers
# Get Team API Key from SendX Settings -> API & Webhooks / Team API Key
SENDX_TEAM_API_KEY=your_sendx_team_api_key_here
# Audience list from https://app.sendx.io/audience/list/details/344558/overview
SENDX_NEWSLETTER_LIST_ID=344558
# Optional comma-separated tags added to every subscriber
SENDX_NEWSLETTER_TAGS=doomsday-clock-updates,2027-announcement
# Optional default source tag added alongside popup/inline source tags
SENDX_DEFAULT_SOURCE_TAG=doomsdayclock-newsletter

# Frontend URL - used in email verification links
FRONTEND_URL=https://doomsdayclock.net
