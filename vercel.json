{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.doomsdayclock.net" }],
      "destination": "https://doomsdayclock.net/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/news-sitemap.xml", "destination": "/api/news-sitemap" },
    { "source": "/embed/clock", "destination": "/embed.html" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/|embed/).*)", "destination": "/index.html" }
  ]
}
